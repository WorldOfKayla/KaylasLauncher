<ui>
    <panels>
        <panel id="download">
            <panelOptions doubleBuffered="true" background="#373c3975">
                <bounds x="20" y="40" width="800" height="440" />
            </panelOptions>
            <childComponents>
                <component type="progressBar"
                           style="progress"
                           id="progressBar"
                           minValue="0"
                           maxValue="100"
                           initialValue="0"
                           stringPainted="false"
                           fillColor="#b0976bff"
                           trackColor="#202720ff"
                           borderColor="#183824ff"
                           borderWidth="1"
                           borderPainted="true"
                           borderRadius="10"
                           fillBorderRadius="8"
                           trackPadding="2"
                           striped="true"
                           stripeColor="#ffffff22"
                           stripeWidth="12"
                           stripeGap="8"
                           stripeSpeedMs="800"
                           animateValue="true"
                           animationDurationMs="120">
                    <visible/>
                    <enabled/>
                    <bounds x="5" y="370" width="790" height="30" />
                </component>
                <component type="label" fontSize="12" style="title" color="#ffffff" id="progressLabel">
                    <visible/>
                    <enabled/>
                    <bounds x="15" y="5" width="250" height="20" />
                </component>
                <component type="button" style="altButton" imageIcon="fa:cancel" iconWidth="16" iconHeight="16" id="cancelDownload-small">
                    <visible/>
                    <enabled/>
                    <bounds x="760" y="0" width="32" height="32" />
                </component>
            </childComponents>
            <panels>
                <panel id="downloadInfo">
                    <panelOptions cornerRadius="10" background="#b0c1c1">
                        <visible/>
                        <opaque/>
                        <bounds x="300" y="40" width="500" height="300" />
                    </panelOptions>
                    <childComponents>
                        <component type="label" fontSize="14" color="#636c73bf" style="title" imageIcon="fa:file" iconWidth="36" iconHeight="36" id="downloadFile">
                            <visible/>
                            <enabled/>
                            <bounds x="20" y="10" width="600" height="40" />
                        </component>
                        <component type="label" fontSize="14" color="#636c73bf" style="title" imageIcon="fa:folder" iconWidth="36" iconHeight="36" id="downloadDirectory">
                            <visible/>
                            <enabled/>
                            <bounds x="20" y="50" width="600" height="40" />
                        </component>
                        <component type="label" fontSize="14" color="#636c73bf" style="title" imageIcon="fa:speed" iconWidth="36" iconHeight="36" id="downloadSpeed">
                            <visible/>
                            <enabled/>
                            <bounds x="20" y="90" width="600" height="40" />
                        </component>
                    </childComponents>
                </panel>
                <panel id="serverDescription">
                    <panelOptions cornerRadius="10" background="#b0c1c1">
                        <visible/>
                        <opaque/>
                        <bounds x="0" y="40" width="290" height="300" />
                    </panelOptions>
                    <childComponents>
                        <component type="textArea" lineWrap="true" editable="false" style="textFieldMain" fontSize="13" border="5,5,5,5" color="#7e7d7c" id="serverDescArea">
                            <visible/>
                            <disabled/>
                            <bounds x="10" y="10" width="240" height="290" />
                        </component>
                    </childComponents>
                </panel>
            </panels>
        </panel>
    </panels>
</ui>
