{
  panels: {
    generalSettings: {
      panelOptions: {
        opaque: false,
        focusable: true,
        visible: true,
        bounds: {
          x: 0,
          y: 0,
          size: {
            width: 490,
            height: 450
          }
        },
        display: true
      },
      childComponents: [
        {
          type: "label",
          fontSize: 14,
          style: "titleBold",
          imageIcon: "assets/ui/icons/settings.svg",
          iconWidth: 32,
          iconHeight: 32,
          localeKey: "settings.baseOptions",
          id: "baseOptions",
          bounds: {
            x: 5,
            y: 20,
            size: {
              width: 270,
              height: 60
            }
          }
        },
        {
          panels: {
            settingsFields: {
              panelOptions: {
                opaque: true,
                visible: true,
                background: "#c0a1a0f7",
                bounds: {
                  x: 0,
                  y: 20,
                  size: {
                    width: 490,
                    height: 450
                  }
                },
                display: true
              },
              childComponents: [
                {
                  readFrom: "assets/frames/forms/settings/checkBoxes.json5"
                },
                {
                  readFrom: "assets/frames/forms/settings/sliders.json5"
                },
                {
                  type: "button",
                  enabled: true,
                  keyCode: "F",
                  fontSize: 12,
                  toolTip: "tooltip.folder",
                  imageIcon: "assets/ui/icons/dir.png",
                  iconWidth: 32,
                  iconHeight: 32,
                  style: "altButton",
                  localeKey: "settings.homeDir",
                  id: "gameDir-small",
                  bounds: {
                    x: 410,
                    y: 20,
                    size: {
                      width: 64,
                      height: 64
                    }
                  }
                },
                {
                  type: "label",
                  fontSize: 12,
                  style: "promptLabel",
                  localeKey: "settings.langBox",
                  id: "langBoxLabel",
                  bounds: {
                    x: 40,
                    y: 290,
                    size: {
                      width: 250,
                      height: 50
                    }
                  }
                },
                {
                  type: "dropBox",
                  style: "selectable",
                  id: "lang",
                  bounds: {
                    x: 40,
                    y: 325,
                    size: {
                      width: 273,
                      height: 25
                    }
                  }
                },
                {
                  type: "fileSelector" ,
                  selectionMode: "DIRECTORIES_ONLY",
				  background: "assets/ui/components/input/textField.png",
                  initialValue: "config#homeDir",
                  id: "homeDir" ,
                  bounds: {
                    x: 40,
                    y: 380,
                    size: {
                      width: 262 ,
                      height: 45
                    }
                  }
                },
                {
                  type: "button",
