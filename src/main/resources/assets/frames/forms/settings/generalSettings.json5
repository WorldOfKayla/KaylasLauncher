                  keyCode: "ENTER",
                  toolTip: "tooltip.applySettings",
                  tooltipStyle: "success",
                  style: "buttonMain",
                  id: "applySettings",
                  localeKey: "settings.applySettings",
                  bounds: {
                    x: 300,
                    y: 380,
                    size: {
                      width: 200,
                      height: 47
                    }
                  }
