<ui>
    <panels>
        <panel id="userActions">
            <panelOptions opaque="false" focusable="true" visible="true" doubleBuffered="false">
                <bounds x="0" y="0" width="350" height="500"/>
            </panelOptions>
            <childComponents>
                <component>
                    <panels>
                        <panel id="infoPane">
                            <panelOptions opaque="true" focusable="true" visible="true" doubleBuffered="true"
                                          background="#b6aaa0" zIndex="3">
                                <bounds x="0" y="30" width="348" height="43"/>
                            </panelOptions>
                            <childComponents>
                                <component type="button" enabled="true" keyCode="U" style="altButton"
                                           imageIcon="fa:menu" iconWidth="20" iconHeight="24" id="userPane">
                                    <bounds x="10" y="5" width="32" height="32"/>
                                    <scripts>
                                        <script event="action" path="assets/scripts/launcher/launcher-ui.lua"/>
                                    </scripts>
                                </component>
                                <component type="label" fontSize="14" style="title" color="#5a1ab3" id="greetUser"
                                           localeKey="logged.greet">
                                    <bounds x="50" y="5" width="320" height="30"/>
                                </component>
                            </childComponents>
                        </panel>
                    </panels>
                </component>
                <component>
                    <panels>
                        <panel id="userControls">
                            <panelOptions opaque="false" focusable="true" visible="true" doubleBuffered="false">
                                <bounds x="0" y="30" width="350" height="500"/>
                            </panelOptions>
                            <childComponents>
                                <component type="label" fontSize="14" style="titleBold" id="userSkin" localeKey="">
                                    <bounds x="110" y="75" width="120" height="230"/>
                                </component>
                                <component type="button" enabled="true" keyCode="ENTER" style="buttonMain"
                                           toolTip="tooltip.gameTooltip" tooltipStyle="success" id="toGame"
                                           localeKey="logged.toGame">
                                    <bounds x="32" y="315" width="225" height="43"/>
                                </component>
                                <component type="button" enabled="true" keyCode="O" style="altButton"
                                           toolTip="tooltip.optionalMods" imageIcon="fa:settings" iconWidth="16"
                                           iconHeight="16" tooltipStyle="success" id="optionalMods">
                                    <bounds x="258" y="315" width="45" height="43"/>
                                    <scripts>
                                        <script event="action" path="assets/scripts/launcher/launcher-ui.lua"/>
                                    </scripts>
                                </component>
                                <component type="combobox" style="selectable" id="serverBox" initialValue="servers"
                                           toolTip="tooltip.selectServer">
                                    <bounds x="35" y="368" width="275" height="30"/>
                                    <scripts>
                                        <script event="init" path="assets/scripts/launcher/launcher-ui.lua"/>
                                        <script event="valuesChanged" path="assets/scripts/launcher/launcher-ui.lua"/>
                                    </scripts>
                                </component>
                                <component type="checkBox" enabled="true" style="solid" id="forceUpdate" localeKey="logged.forceUpdate" initialValue="false">
                                    <bounds x="32" y="410" width="275" height="32"/>
                                </component>
                                <component>
                                    <panels>
                                        <panel id="serverLaunchPanel">
                                            <panelOptions opaque="true" focusable="false" visible="true"
                                                          doubleBuffered="true" background="#b6aaa0" cornerRadius="12" zIndex="999">
                                                <bounds x="20" y="300" width="310" height="155"/>
                                            </panelOptions>
                                            <childComponents/>
                                        </panel>
                                    </panels>
                                </component>
                            </childComponents>
                        </panel>
                    </panels>
                </component>
            </childComponents>
        </panel>
    </panels>
</ui>
