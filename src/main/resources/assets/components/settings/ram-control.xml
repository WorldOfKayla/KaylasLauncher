<?xml version="1.0" encoding="UTF-8"?>
<ui>
    <childComponents>
        <component
            type="label"
            id="label"
            style="title"
            localeKey="settings.ramField"
            fontSize="12"
            opaque="false"
            visible="true">
            <bounds x="0" y="0" width="290" height="25" />
        </component>

        <component
            type="launcherSliderTrack"
            id="slider"
            style="slidingOut"
            stepSize="6"
            minorSpacing="512"
            majorSpacing="1024"
            initialValue="config#ramAmount"
            opaque="false"
            visible="true">
            <bounds x="0" y="20" width="300" height="45" />
            <styles>
                <style target="tickLabel" name="title" />
            </styles>
            <properties>
                <property name="launcher.slider.ram" value="true" type="boolean" />
            </properties>
            <scripts>
                <script event="init" path="assets/scripts/launcher/component-links.lua" />
            </scripts>
        </component>

        <component
            type="launcherSettingSpinner"
            id="spinner"
            stepSize="512"
            initialValue="config#ramAmount"
            opaque="false"
            visible="true">
            <bounds x="320" y="15" width="80" height="30" />
            <properties>
                <property name="launcher.slider.ram" value="true" type="boolean" />
            </properties>
            <scripts>
                <script event="init" path="assets/scripts/launcher/component-links.lua" />
            </scripts>
        </component>
    </childComponents>
</ui>
