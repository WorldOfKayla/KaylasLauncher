{
  "launcherBrand": "FoxesLauncher",
  "launcherVersion": "1.7.4-Treta",
  "styles": ["button",  "checkBox", "label", "multiButton", "passField", "progressBar", "dropBox", "serverBox", "textField", "slider"],
  "logLevel": "INFO",
  "programRuntime": "jdk-17.0.9",
  "bindUrl": "https://foxescraft.ru",
  "appId": "712667904956432456",
  "accessToken": "ccdd6e40ccdd6e40ccdd6e40ecccaf012ecccddccdd6e4092074eb9f3eea48edf8a6e39",
  "groupDomain": "foxesworlds1",
  "vkAPIversion": "5.101",
  "files": {
    "frameTpl": "assets/frames/frame.json",
    "mainFrame": "assets/frames/mainFrame.json",
    "localeFile": "/assets/lang/locale.json",
    "soundsFile": "assets/sounds/sounds.json"
  },
  "loadManager": [
    {
	  "path": "assets/ui/sprites/loaderGrid.png",
	  "rows": 3,
	  "cols": 5,
	  "delay": 50,
	  "x": 30,
	  "y": 30,
	  "width": 64,
	  "height": 64
  }
  ],
  "requestProperties": [
    {
      "propertyKey": "User-Agent",
      "propertyValue": "FoxesWorldLauncher"
    },
    {
      "propertyKey": "Accept-Language",
      "propertyValue": "ru-RU,ru;q=0.8,en-US;q=0.6,en;q=0.4"
    },
    {
      "propertyKey": "Accept",
      "propertyValue": "text/json,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8"
    },
    {
      "propertyKey": "Content-Type",
      "propertyValue": "application/x-www-form-urlencoded; charset=UTF-8; boundary={$boundary}"
    }
  ],
  "tweakClasses": [
     "net.minecraftforge.fml.common.launcher.FMLTweaker",
     "cpw.mods.fml.common.launcher.FMLTweaker",
     "com.mumfrey.liteloader.launch.LiteLoaderTweaker",
     "org.dimdev.riftloader.launch.RiftLoaderClientTweaker",
     "optifine.OptiFineTweaker"
  ],
  "downloadManager": {
    "downloadThreads": 4,
    "replaceMasks": [
      {
        "mask": "/uploads/files/clients/",
        "replace": "/uploads/files/clients/"
      },
      {
        "mask": "/uploads/files/clients/versions/${version}/libraries/",
        "replace": "/uploads/files/clients/versions/${version}/"
      }
    ]
  }
}