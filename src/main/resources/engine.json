{
  "launcherBrand": "Kayla's Launcher",
  "launcherVersion": "2.0.0",
  "launcherBuild": "Anderson",
  "styles": [
    "button",
    "checkBox",
    "label",
    "multiButton",
    "passField",
    "progressBar",
    "combobox",
    "dropBox",
    "textField",
    "textArea",
    "slider",
    "spinner",
    "compositeSlider"
  ],
  "loadAdapters": [
    "xml",
    "json",
    "json5"
  ],
  "logLevel": "INFO",
  "programRuntime": "jdk-17.0.11",
  "bindUrl": "",
  "backend": {
    "enabled": true,
    "wsUrl": "wss://api.kaylas-systems.ru/ws/launcher",
    "heartbeatSeconds": 15,
    "maxReconnectAttempts": 0
  },
  "appId": "1524737795942256660",
  "files": {
    "frameTpl": "assets/frames/frame.json5",
    "mainFrame": "assets/frames/mainFrame.json5",
    "localeFile": "assets/lang/",
    "soundsFile": "assets/sounds/sounds.json"
  },
  "loadManager": [
    {
      "spritePath": "assets/ui/sprites/loaderFox.png",
      "bgPath": "assets/ui/img/bg/season/summer.png",
      "blurColor": "#b3a8998a",
      "titleColor": "#252424",
      "descColor": "#7534d4",
      "rows": 3,
      "cols": 5,
      "delay": 55,
      "animSpeed": 55,
      "bounds": {
        "x": 30,
        "y": 40,
        "size": {
          "width": 64,
          "height": 64
        }
      }
    },
    {
      "spritePath": "assets/ui/sprites/exp.png",
      "bgPath": "assets/ui/img/bg/season/summer.png",
      "blurColor": "#b3a8998a",
      "titleColor": "#ffffff",
      "descColor": "#473c3c",
      "rows": 7,
      "cols": 6,
      "delay": 50,
      "animSpeed": 65,
      "bounds": {
        "x": 30,
        "y": 40,
        "size": {
          "width": 64,
          "height": 64
        }
      }
    }
  ],
  "httpConf": {
    "useCaches": false,
    "doInput": true,
    "doOutput": true,
    "requestProperties": [
      {
        "propertyKey": "User-Agent",
        "propertyValue": "TakeSomeLauncher"
      },
      {
        "propertyKey": "Accept-Language",
        "propertyValue": "ru-RU,ru;q=0.8,en-US;q=0.6,en;q=0.4"
      },
      {
        "propertyKey": "Accept",
        "propertyValue": "text/json,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8"
      },
      {
        "propertyKey": "Content-Type",
        "propertyValue": "application/x-www-form-urlencoded; charset=UTF-8; boundary={$boundary}"
      }
    ]
  },
  "tweakClasses": [
    "net.minecraftforge.fml.common.launcher.FMLTweaker",
    "cpw.mods.fml.common.launcher.FMLTweaker",
    "com.mumfrey.liteloader.launch.LiteLoaderTweaker",
    "org.dimdev.riftloader.launch.RiftLoaderClientTweaker",
    "optifine.OptiFineTweaker"
  ],
  "downloadManager": {
    "downloadThreads": 4,
    "replaceMasks": [
      {
        "mask": "/uploads/files/clients/",
        "replace": "/uploads/files/clients/"
      },
      {
        "mask": "/uploads/files/clients/versions/${version}/libraries/",
        "replace": "/uploads/files/clients/versions/${version}/"
      }
    ]
  }
}
