{
  "bindUrl": "https://foxescraft.ru",
  "requestProperties": [
    {
      "propertyKey": "User-Agent",
      "propertyValue": "FoxesWorldLauncher"
    },
    {
      "propertyKey": "Accept-Language",
      "propertyValue": "ru-RU,ru;q=0.8,en-US;q=0.6,en;q=0.4"
    },
    {
      "propertyKey": "Accept",
      "propertyValue": "text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8"
    },
    {
      "propertyKey": "Content-Type",
      "propertyValue": "application/x-www-form-urlencoded; boundary={$boundary}"
    }
  ],
  "tweakClasses": [
    {
      "classPath": "com.mumfrey.liteloader.launch.LiteLoaderTweaker"
    },
    {
      "classPath": "cpw.mods.fml.common.launcher.FMLTweaker"
    },
    {
      "classPath": "net.minecraftforge.fml.common.launcher.FMLTweaker"
    },
    {
      "classPath": "org.dimdev.riftloader.launch.RiftLoaderClientTweaker"
    },
    {
      "classPath": "optifine.OptiFineTweaker"
    }
  ]
}