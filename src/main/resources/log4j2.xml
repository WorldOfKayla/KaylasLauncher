<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <Property name="logDir">${sys:log.dir:-${sys:user.dir}}</Property>
    </Properties>

    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout
                    pattern="%style{[%d{HH:mm:ss}]}{bold,black} %highlight{[%p]}{FATAL=bg_red, ERROR=red, WARN=yellow, INFO=green, DEBUG=blue, TRACE=cyan} %style{%X{workerName}{[Name-%X{workerName}]}}{magenta} %style{%m}{black}%n"
                    disableAnsi="false" />
        </Console>

        <File name="File" fileName="${logDir}/logs/lastlog.log" append="false">
            <PatternLayout
                    pattern="[%d{HH:mm:ss.SSS}][%p]%X{workerName}{[Name-%X{workerName}]} %m%n" />
        </File>

        <RollingFile name="SecureProcessFile"
                     fileName="${logDir}/logs/secure-process.log"
                     filePattern="${logDir}/logs/archive/secure-process-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout
                    pattern="[%d{yyyy-MM-dd HH:mm:ss.SSS}][%p][%t][%c] %m%n" />
            <Policies>
                <OnStartupTriggeringPolicy />
                <SizeBasedTriggeringPolicy size="5 MB" />
            </Policies>
            <DefaultRolloverStrategy max="10" />
        </RollingFile>
    </Appenders>

    <Loggers>
        <Logger name="SecureProcess" level="DEBUG" additivity="false">
            <AppenderRef ref="Console" />
            <AppenderRef ref="SecureProcessFile" />
        </Logger>

        <Root level="DEBUG">
            <AppenderRef ref="Console" />
            <AppenderRef ref="File" />
        </Root>
    </Loggers>
</Configuration>
