{
  panels: {
    authForm: {
      panelOptions: {
        opaque: false,
        focusable: true,
        visible: true,
        doubleBuffered: false,
        background: "",
        bounds: {
          x: 0,
          y: 0,
          size: {
            width: 350,
            height: 500
          }
        }
      },
      childComponents: [
        {
          type: "textField",
          style: "textFieldMain",
          localeKey: "auth.loginPlaceholder",
          id: "login",
          bounds: {
            x: 45,
            y: 150,
            size: {
              width: 262,
              height: 45
            }
          }
        },
        {
          type: "passField",
          style: "textFieldMain",
          localeKey: "auth.passwordPlaceholder",
          showIcon: "assets/ui/icons/show.svg",
          hideIcon: "assets/ui/icons/hide.svg",
          revealButton: true,
          id: "password",
          bounds: {
            x: 45,
            y: 220,
            size: {
              width: 262,
              height: 45
            }
          }
        },
        {
          type: "label",
          fontSize: 25,
          style: "titleBold",
          localeKey: "auth.authTitle",
          id: "appHeader",
          bounds: {
            x: 50,
            y: 50,
            size: {
              width: 340,
              height: 50
            }
          }
        },
        {
          type: "checkBox",
          enabled: true,
          style: "solid",
          id: "rememberMe",
          localeKey: "auth.rememberMe",
          bounds: {
            x: 40,
            y: 265,
            size: {
              width: 240,
              height: 32
            }
          }
        },
        {
          type: "button",
          enabled: true,
          keyCode: "ENTER",
          style: "buttonMain",
          id: "authForm>submit",
          localeKey: "auth.submit",
          bounds: {
            x: 55,
            y: 300,
            size: {
              width: 240,
              height: 47
            }
          }
        },
        {
          type: "button",
          enabled: true,
          style: "altButton",
          toolTip: "tooltip.settings",
          imageIcon: "assets/ui/icons/settings.png",
          iconWidth: 32,
          iconHeight: 32,
          id: "settings-small",
          bounds: {
            x: 280,
            y: 435,
            size: {
              width: 64,
              height: 64
            }
          }
        }
      ]
    }
  }
}